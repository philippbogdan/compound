# tribeux-server — environment variables
#
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# `.env` is loaded automatically when you run `uv run` / `uvicorn` from this
# directory if you `set -a; source .env; set +a` first, or use a tool like
# `dotenv` / `direnv`.

# ---------------------------------------------------------------------------
# Claude analyst (tribeux_server.claude_analyst)
# ---------------------------------------------------------------------------

# 1 (default): use the deterministic mock analyst — no network, no key needed.
# 0:           call the live Anthropic API. Requires ANTHROPIC_API_KEY below.
#
# When MOCK_CLAUDE=1 (or unset) OR ANTHROPIC_API_KEY is missing, the server
# falls back to the mock and the report headline shows "(mock claude)".
MOCK_CLAUDE=1

# Anthropic API key. Only read when MOCK_CLAUDE=0.
# Get one at https://console.anthropic.com/settings/keys
# IMPORTANT: never commit a real key. Treat any key shared in chat or in a
# public diff as compromised — rotate immediately.
ANTHROPIC_API_KEY=

# Optional: which Claude model to use. Defaults to claude-3-5-sonnet-latest.
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
